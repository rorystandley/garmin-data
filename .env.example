# Garmin Connect credentials — copy to .env and fill in your values
# Never commit .env to version control

# Required: your Garmin Connect account credentials
GARMIN_EMAIL=your@email.com
GARMIN_PASSWORD=yourpassword

# Optional: directory to persist Garmin auth tokens between runs
# Defaults to ~/.garmin_tokens
GARMIN_TOKEN_DIR=~/.garmin_tokens

# Optional: path to the SQLite database file
# Defaults to ~/garmin_data.db
GARMIN_DB_PATH=~/garmin_data.db

# Optional: default number of days to sync when --days is not specified
# Defaults to 30
GARMIN_SYNC_DAYS_DEFAULT=30

# Optional: logging level (DEBUG, INFO, WARNING, ERROR)
# Defaults to INFO
GARMIN_LOG_LEVEL=INFO
